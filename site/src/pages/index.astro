---
import Base from "../layouts/Base.astro";

const repo = "julianyaman/apfelclaw";
const brewInstall = `brew tap julianYaman/apfelclaw
brew install apfelclaw`;

const installStep = `apfelclaw
# complete onboarding`;

const altScripts = `apfelclaw setup       # rerun onboarding
apfelclaw serve       # foreground backend
apfelclaw chat        # launch chat app
apfelclaw --status    # rich local status`;

const configExample = JSON.stringify(
  {
    assistantName: "Apfelclaw",
    userName: "You",
    approvalMode: "trusted-readonly",
    debug: false,
  },
  null,
  2,
);
---

<Base
  title="apfelclaw — local AI agent for macOS"
  description="A locally running AI agent for macOS tasks using Apple's Foundation model. Open source, private by design."
>
  <!-- ───────── NAV ───────── -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-icon">🍏</span>
        <span class="logo-text">apfelclaw</span>
      </a>
      <div class="nav-links">
        <a href="/docs/getting-started">Docs</a>
        <a href="#features">Features</a>
        <a href="#quickstart">Quick start</a>
        <a
          href={`https://github.com/${repo}`}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-gh"
        >
          <img
            src={`https://img.shields.io/github/stars/${repo}?style=flat&color=79C94B&labelColor=24301C&logo=github`}
            alt="GitHub stars"
            class="star-badge-nav"
          />
        </a>
      </div>
    </div>
  </nav>

  <!-- ───────── HERO ───────── -->
  <header class="hero">
    <div class="container">
      <span class="hero-badge">Experimental</span>
      <img
        src="/apfelclaw.png"
        alt="apfelclaw logo"
        class="hero-logo"
        width="140"
        height="140"
      />
      <h1>apfelclaw</h1>
      <p class="hero-sub">
        A locally running AI agent for macOS tasks, powered by Apple's
        Foundation model via <a
          href="https://github.com/Arthur-Ficial/apfel"
          target="_blank"
          rel="noopener noreferrer">apfel</a
        >.
      </p>
      <div class="hero-install">
        <button
          type="button"
          class="copy-brew"
          data-copy-brew
          aria-label="Copy brew install commands"
          title="Copy brew install commands"
        >
          <span class="copy-brew-tooltip copy-brew-tooltip-copy">Copy</span>
          <span class="copy-brew-tooltip copy-brew-tooltip-copied">Copied</span>
          <span class="copy-brew-icon" aria-hidden="true">
            <svg class="copy-brew-icon-default" viewBox="0 0 24 24" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </g>
            </svg>
            <svg class="copy-brew-icon-success" viewBox="0 0 24 24" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 15 2 2 4-4" />
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </g>
            </svg>
          </span>
        </button>
        <pre><code id="hero-brew-command">{brewInstall}</code></pre>
      </div>
      <div class="hero-actions">
        <a href={`https://github.com/${repo}`} class="btn btn-primary">
          View on GitHub
        </a>
        <a href="/docs/getting-started" class="btn btn-secondary"> Docs </a>
        <a href="#quickstart" class="btn btn-secondary"> Get started </a>
      </div>
      <div class="hero-badges">
        <img
          src={`https://img.shields.io/github/license/${repo}?style=flat&color=A7E163&labelColor=24301C`}
          alt="License"
        />
        <img
          src={`https://img.shields.io/github/stars/${repo}?style=flat&color=79C94B&labelColor=24301C`}
          alt="Stars"
        />
        <img
          src={`https://img.shields.io/github/last-commit/${repo}?style=flat&color=79C94B&labelColor=24301C`}
          alt="Last commit"
        />
        <img
          src={`https://img.shields.io/github/issues/${repo}?style=flat&color=A7E163&labelColor=24301C`}
          alt="Open issues"
        />
      </div>
    </div>
  </header>

  <!-- ───────── NOTICE ───────── -->
  <section class="notice">
    <div class="container">
      <div class="notice-box">
        <strong>Early development</strong> — This project is an experiment
        exploring how well Apple's Foundation model works as an agent. It is not
        meant for production use or real-world tasks yet. Use at your own risk —
        we cannot guarantee its reliability or security.
      </div>
    </div>
  </section>

  <!-- ───────── SHOWCASE ───────── -->
  <section class="showcase">
    <div class="container">
      <div class="showcase-wrapper">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          poster=""
          aria-label="apfelclaw demo — terminal AI agent in action"
        >
          <source src="/apfelclaw-showcase.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </section>

  <!-- ───────── STRUCTURE ───────── -->
  <section id="features" class="section">
    <div class="container">
      <h2>Project structure</h2>
      <p class="section-lead">
        The repository is organized as a small monorepo with a Swift backend and
        a terminal UI client, with optional Telegram remote control backed by the
        same local runtime.
      </p>
      <div class="card-grid">
        <div class="card">
          <div class="card-icon">⚙️</div>
          <h3>Swift backend</h3>
          <p>
            Swift backend runtime — local API, tool execution, conversation
            management, and persistence.
          </p>
          <code>packages/apfelclaw-server</code>
        </div>
        <div class="card">
          <div class="card-icon">🖥️</div>
          <h3>Chat app</h3>
          <p>
            Separate terminal chat application built with <a
              href="https://opentui.dev"
              target="_blank"
              rel="noopener noreferrer">OpenTUI</a
            > and Bun, connecting to the local API.
          </p>
          <code>apps/tui</code>
        </div>
        <div class="card">
          <div class="card-icon">✈️</div>
          <h3>Telegram connection</h3>
          <p>
            Optional remote access through a private Telegram bot, linked during
            onboarding or later from chat, and handled by the local backend.
          </p>
          <code>/remotecontrol setup telegram</code>
        </div>
        <div class="card">
          <div class="card-icon">🚀</div>
          <h3>Command tool</h3>
          <p>
            The Node-based <code>apfelclaw</code> CLI owns onboarding, service
            lifecycle, status, updates, and chat launch.
          </p>
          <code>apfelclaw</code>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────── STATUS ───────── -->
  <section class="section section-alt">
    <div class="container">
      <h2>Status</h2>
      <p class="section-lead">
        Currently macOS-only. The backend depends on Apple platform APIs like
        EventKit, Apple Mail, and Spotlight-backed file search, and expects <code
          >apfel</code
        > to be installed locally for model execution. Homebrew installs also
        pull in the Node runtime for the command tool.
      </p>
    </div>
  </section>

  <!-- ───────── PREREQUISITES ───────── -->
  <section class="section">
    <div class="container">
      <h2>Prerequisites</h2>
      <ul class="prereq-list">
        <li><strong>Apple Silicon</strong> with macOS 26 Tahoe or newer</li>
        <li><strong>Node.js 18+</strong> if installing from source</li>
        <li><strong>Swift 6.3+</strong> if building the backend from source</li>
        <li><strong>Bun 1.0+</strong> only for local chat development builds</li>
        <li>
          <code>apfel</code> installed and available on <code>PATH</code>
        </li>
      </ul>
    </div>
  </section>

  <!-- ───────── QUICKSTART ───────── -->
  <section id="quickstart" class="section section-alt">
    <div class="container">
      <h2>Quick start</h2>
      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Install with Homebrew</h3>
            <pre><code>{brewInstall}</code></pre>
            <p class="step-note">
              This installs the command tool, chat app, and backend runtime.
            </p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Run onboarding</h3>
            <pre><code>{installStep}</code></pre>
            <p class="step-note">
              The onboarding guide saves your defaults, starts the backend, and
              can optionally set up Telegram.
            </p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Launch chat</h3>
            <pre><code>apfelclaw chat</code></pre>
          </div>
        </div>
      </div>
      <p class="steps-alt">
        Or use the root convenience scripts:
      </p>
      <pre><code>{altScripts}</code></pre>
      <br />
      <p class="steps-alt">
        Need a prompt to start with? Try <a href="https://bearprompt.com/prompts/apfelclaw" target="_blank" rel="noopener noreferrer">Starter Prompts</a>.
      </p>
    </div>
  </section>

  <!-- ───────── API ───────── -->
  <section id="api" class="section">
    <div class="container">
      <h2>API endpoints</h2>
      <p class="section-lead">
        The backend exposes a local REST API with WebSocket support for live
        session events.
      </p>
      <div class="api-table-wrap">
        <table class="api-table">
          <thead>
            <tr>
              <th>Method</th>
              <th>Endpoint</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><span class="method get">GET</span></td><td>/health</td></tr>
            <tr><td><span class="method get">GET</span></td><td>/config</td></tr>
            <tr><td><span class="method patch">PATCH</span></td><td>/config</td></tr>
            <tr><td><span class="method get">GET</span></td><td>/tools</td></tr>
            <tr><td><span class="method get">GET</span></td><td>/sessions</td></tr>
            <tr><td><span class="method post">POST</span></td><td>/sessions</td></tr>
            <tr>
              <td><span class="method get">GET</span></td>
              <td>/sessions/:id/messages</td>
            </tr>
            <tr>
              <td><span class="method post">POST</span></td>
              <td>/sessions/:id/messages</td>
            </tr>
            <tr>
              <td><span class="method ws">WS</span></td>
              <td>/sessions/:id/stream</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="api-note">
        Response header: <code>Server: apfelclaw/0.2.0</code>
      </p>
    </div>
  </section>

  <!-- ───────── CONFIG ───────── -->
  <section class="section section-alt">
    <div class="container">
      <h2>Configuration</h2>
      <p class="section-lead">
        Config lives in <code>~/.apfelclaw/config.json</code> and persists
        across server restarts. Install state is stored at <code>~/.apfelclaw/state.json</code>. SQLite memory is stored at <code
          >~/.apfelclaw/memory.sqlite</code
        >.
      </p>
      <pre><code>{configExample}</code></pre>
      <p class="config-detail">
        Supported <code>approvalMode</code> values: <code>always</code>, <code
          >ask-once-per-tool-per-session</code
        >, <code>trusted-readonly</code>.
      </p>
    </div>
  </section>

  <!-- ───────── CONTRIBUTING ───────── -->
  <section class="section">
    <div class="container">
      <h2>Contributing</h2>
      <p class="section-lead">
        Contribution guidelines live in <a
          href={`https://github.com/${repo}/blob/main/CONTRIBUTING.md`}
          target="_blank"
          rel="noopener noreferrer"><code>CONTRIBUTING.md</code></a
        >. Please read that file before opening a pull request.
      </p>
    </div>
  </section>

  <!-- ───────── FOOTER ───────── -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="logo-icon">🍏</span>
        <span class="footer-name">apfelclaw</span>
        <span class="footer-sep">·</span>
        <span class="footer-license">MIT License</span>
      </div>
      <div class="footer-right">
        <a
          href={`https://github.com/${repo}`}
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >
        <a
          href={`https://github.com/${repo}/blob/main/CONTRIBUTING.md`}
          target="_blank"
          rel="noopener noreferrer">Contributing</a
        >
        <a
          href={`https://github.com/${repo}/blob/main/LICENSE`}
          target="_blank"
          rel="noopener noreferrer">License</a
        >
        <a
          href="https://yaman.pro"
          target="_blank"
          rel="noopener noreferrer">yaman.pro</a
        >
      </div>
    </div>
  </footer>
</Base>

<style>
  /* ─── Nav ─── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 253, 244, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(121, 201, 75, 0.15);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--text-main);
  }

  .nav-logo:hover {
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.3rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .nav-links a {
    color: var(--text-muted);
  }

  .nav-links a:hover {
    color: var(--leaf-green);
    text-decoration: none;
  }

  .nav-gh {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .star-badge-nav {
    height: 18px;
    vertical-align: middle;
  }

  /* ─── Container ─── */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ─── Hero ─── */
  .hero {
    padding: 5rem 0 3.5rem;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--fresh-lime);
    color: var(--text-main);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3em 0.9em;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero-logo {
    display: block;
    margin: 0 auto;
    width: 140px;
    height: 140px;
    object-fit: contain;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 540px;
    margin: 0 auto 2rem;
  }

  .hero-install {
    position: relative;
    max-width: 440px;
    margin: 0 auto 1.5rem;
    text-align: left;
  }

  .hero-install pre {
    margin: 0;
    padding-right: 3rem;
  }

  .copy-brew {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: transform 0.12s ease, background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
  }

  .copy-brew::after {
    content: '';
    position: absolute;
    left: 50%;
    top: -0.45rem;
    width: 0;
    height: 0;
    border-left: 0.35rem solid transparent;
    border-right: 0.35rem solid transparent;
    border-top: 0.35rem solid rgba(16, 24, 16, 0.98);
    opacity: 0;
    transform: translate(-50%, 0.15rem);
    transition: opacity 0.12s ease, transform 0.12s ease;
  }

  .copy-brew-tooltip {
    position: absolute;
    left: 50%;
    top: -0.45rem;
    padding: 0.28rem 0.5rem;
    border-radius: 0.45rem;
    background: rgba(16, 24, 16, 0.98);
    color: #fff;
    font-size: 0.68rem;
    line-height: 1;
    letter-spacing: 0.01em;
    white-space: nowrap;
    opacity: 0;
    transform: translate(-50%, calc(-100% - 4px));
    pointer-events: none;
    transition: opacity 0.12s ease, transform 0.12s ease;
  }

  .copy-brew-tooltip-copied {
    display: none;
  }

  .copy-brew:hover {
    transform: translateY(-1px);
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .copy-brew:hover .copy-brew-tooltip-copy,
  .copy-brew:focus-visible .copy-brew-tooltip-copy {
    opacity: 1;
    transform: translate(-50%, calc(-100% - 4px));
  }

  .copy-brew:focus-visible {
    outline: 2px solid var(--fresh-lime);
    outline-offset: 2px;
  }

  .copy-brew.is-copied {
    color: var(--leaf-green);
    background: rgba(167, 225, 99, 0.12);
    border-color: rgba(167, 225, 99, 0.24);
  }

  .copy-brew.is-copied .copy-brew-icon-default {
    display: none;
  }

  .copy-brew.is-copied .copy-brew-icon-success {
    display: block;
  }

  .copy-brew.is-copied .copy-brew-tooltip-copy {
    display: none;
  }

  .copy-brew.is-copied .copy-brew-tooltip-copied {
    display: block;
    opacity: 1;
    transform: translate(-50%, calc(-100% - 4px));
  }

  .copy-brew-icon {
    width: 1rem;
    height: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .copy-brew-icon svg {
    width: 100%;
    height: 100%;
  }

  .copy-brew-icon-success {
    display: none;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s ease, transform 0.1s ease;
  }

  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--apple-peel);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--leaf-green);
  }

  .btn-secondary {
    background: var(--apple-flesh);
    color: var(--text-main);
  }

  .btn-secondary:hover {
    background: #e9f0c6;
  }

  .hero-badges {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .hero-badges img {
    height: 22px;
  }

  /* ─── Notice ─── */
  .notice {
    padding: 0 0 1rem;
  }

  .notice-box {
    max-width: 660px;
    margin: 0 auto;
    background: #fef6e0;
    border: 1px solid #e5d5a0;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: var(--stem-brown);
    text-align: center;
  }

  /* ─── Showcase ─── */
  .showcase {
    padding: 2rem 0 1rem;
  }

  .showcase-wrapper {
    max-width: 720px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    border: 5px solid rgba(121, 201, 75, 0.5);
    box-shadow: 0 6px 30px rgba(36, 48, 28, 0.12);
  }

  .showcase-wrapper video {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ─── Sections ─── */
  .section {
    padding: 4rem 0;
  }

  .section-alt {
    background: var(--apple-flesh);
  }

  .section h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .section-lead {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 640px;
    margin-bottom: 2rem;
  }

  /* ─── Cards ─── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: #fff;
    border: 1px solid rgba(121, 201, 75, 0.18);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .card-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  /* ─── Prerequisites ─── */
  .prereq-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .prereq-list li {
    background: #fff;
    border: 1px solid rgba(121, 201, 75, 0.18);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
  }

  /* ─── Steps ─── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-bottom: 2rem;
  }

  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-num {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--apple-peel);
    color: #fff;
